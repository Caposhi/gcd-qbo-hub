# ============================================================================
# GCD QBO Hub — environment. Copy to .env.local for local dev; on Render these
# are set per render.yaml (secrets with `sync: false` are entered by hand).
# NEVER commit real secrets. QBO tokens are additionally encrypted at rest in
# the database (see APP_ENCRYPTION_KEY) — env vars are only the bootstrap seed.
# ============================================================================

# --- core ---
# Public HTTPS base URL of the deployed hub. Must be stable BEFORE finalizing
# the QBO OAuth redirect URI in the Intuit developer dashboard (see README §QBO).
PUBLIC_APP_URL=https://gcd-qbo-hub.onrender.com
# Postgres connection string (Render provides this via the database in render.yaml).
DATABASE_URL=postgresql://user:pass@localhost:5432/gcd_qbo_hub?schema=public
# 32-byte key (hex or base64) used to encrypt QBO tokens at rest. Generate with:
#   openssl rand -hex 32
APP_ENCRYPTION_KEY=

# --- auth (NextAuth / Auth.js — email magic-link, restricted to the domain) ---
NEXTAUTH_URL=https://gcd-qbo-hub.onrender.com
# openssl rand -hex 32
NEXTAUTH_SECRET=
# Only addresses on this domain may sign in. Comma-separated for extra domains.
ALLOWED_EMAIL_DOMAINS=germancardepot.com
# The first user to sign in with this address is provisioned as owner_admin.
BOOTSTRAP_OWNER_EMAIL=michaelc@germancardepot.com
# Bootstrap escape hatch: set to "true" to ALSO print the magic sign-in link to
# the server logs (Render → Logs) when a link is requested. Use once to get in
# if corporate mail filtering swallows the email, then set back to false — the
# link is a single-use credential.
MAGIC_LINK_DEBUG=false

# --- console contract gate (shared secret; same pattern as gcd-webhook) ---
# Leave blank to keep /console/* open (fine while the hub URL is private). If
# set, gcd-arcade's BFF must send the matching GCD_QBO_HUB_CONSOLE_TOKEN.
CONSOLE_TOKEN=

# --- internal cron auth (Render Cron Job → protected /api/cron/sync route) ---
# openssl rand -hex 32 — the cron service sends this as `Authorization: Bearer`.
CRON_SECRET=
# End-of-business-day sync time & timezone (informational; the schedule lives in
# render.yaml cron. The route reads TZ to stamp run times consistently).
SYNC_TZ=America/New_York
SYNC_HOUR=19

# --- Google Sheets (service account; same auth plumbing as gcd-webhook) ---
GOOGLE_SHEET_ID=1NGz6sOiJtKOOBZYpM5_0ODZxgHkSQRWYZQqufpotTWA
# Provide EITHER the raw JSON (single line, escaped) OR base64 of the key file.
# The service account's email must be granted at least Viewer on the sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# --- QuickBooks Online (real developer app; sandbox first) ---
# QBO_ENV controls which Intuit base URL is used. Keep `sandbox` until §12
# rollout stages have been advanced deliberately.
QBO_ENV=sandbox
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must exactly match a Redirect URI registered in the Intuit developer dashboard,
# e.g. https://gcd-qbo-hub.onrender.com/api/qbo/callback
QBO_REDIRECT_URI=https://gcd-qbo-hub.onrender.com/api/qbo/callback
QBO_REALM_ID=
# Optional bootstrap tokens. Once connected via the dashboard, the encrypted
# copies in the DB are the source of truth and these are ignored.
QBO_REFRESH_TOKEN=
QBO_ACCESS_TOKEN=
QBO_TOKEN_EXPIRES_AT=

# --- AI Report Assistant module (prototype) ---
# Anthropic API key for the AI Report Assistant (claude-opus-4-8). If unset, the
# assistant shows "not configured" and does not attempt any model calls.
ANTHROPIC_API_KEY=

# --- Tekmetric integration (read-only shop-management data) ---
# Reuses the same env vars as the sibling GCD Tekmetric project. The token is a
# pre-provisioned, long-lived bearer access token sent directly as
# `Authorization: Bearer …`; it is never persisted or logged.
#   BASE_URL: https://shop.tekmetric.com (production) or
#             https://sandbox.tekmetric.com (test)
TEKMETRIC_BASE_URL=https://shop.tekmetric.com
TEKMETRIC_TOKEN=
TEKMETRIC_SHOP_ID=

# --- SendGrid (same proven pattern as gcd-webhook — NOT Gmail) ---
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=alerts@germancardepot.com
# Daily error summary recipient (§17).
ALERT_SUMMARY_RECIPIENT=bills@germancardepot.com
# Changed/removed-after-posting critical alerts recipient (§11, §17).
ALERT_CRITICAL_RECIPIENT=michaelc@germancardepot.com
